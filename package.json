{
  "name": "s3-artifact-upload",
  "description": "An action to upload files to an S3 bucket",
  "version": "2.0.0",
  "author": "Alex Bern (@usualdesigner)",
  "private": true,
  "homepage": "https://github.com/usualdesigner/s3-artifact-upload",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usualdesigner/s3-artifact-upload.git"
  },
  "bugs": {
    "url": "https://github.com/usualdesigner/s3-artifact-upload/issues"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "TypeScript",
    "AWS",
    "S3"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "jest",
    "format:write": "prettier --write **/*.{js,ts}",
    "format:check": "prettier --check **/*.{js,ts}",
    "lint": "npx eslint .",
    "package:watch": "npm run package -- --watch",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release:publish": "node script/publish.mjs",
    "test": "(jest && make-coverage-badge --output-path ./badges/coverage.svg) || make-coverage-badge --output-path ./badges/coverage.svg",
    "all": "npm run format:write && npm run lint && npm run test && npm run package",
    "package": "ncc build src/index.ts --license licenses.txt"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ]
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/lib-storage": "^3.1063.0",
    "fast-glob": "^3.3.3",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^29.5.14",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vercel/ncc": "^0.38.4",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "make-coverage-badge": "^1.2.0",
    "markdownlint-cli": "^0.46.0",
    "prettier": "^3.7.3",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  }
}
